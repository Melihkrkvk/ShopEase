    <mxCell id="210" value="ok" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;dashed=1;fontSize=11;endArrow=open;endFill=0;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="745" y="740" as="sourcePoint" /><mxPoint x="510" y="740" as="targetPoint" /></mxGeometry>
