    <!-- Step 9: persist (self) -->
    <mxCell id="208" value="persist order + items to DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="430" y="630" width="160" height="30" as="geometry" />
