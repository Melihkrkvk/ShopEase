    <mxCell id="203" value="cart items" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;dashed=1;fontSize=11;endArrow=open;endFill=0;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="745" y="370" as="sourcePoint" /><mxPoint x="510" y="370" as="targetPoint" /></mxGeometry>
    </mxCell>

    <!-- Step 5: OrderService -> PaymentFactory -->
    <mxCell id="204" value="create(method)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="510" y="430" as="sourcePoint" /><mxPoint x="980" y="430" as="targetPoint" /></mxGeometry>
    </mxCell>

    <!-- Step 6: PaymentFactory -> OrderService (return) -->
    <mxCell id="205" value="PaymentProvider instance" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;dashed=1;fontSize=11;endArrow=open;endFill=0;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="980" y="480" as="sourcePoint" /><mxPoint x="510" y="480" as="targetPoint" /></mxGeometry>
