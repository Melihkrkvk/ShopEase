    <!-- Step 10: OrderService -> CartService (clear) -->
    <mxCell id="209" value="clear_cart(user_id)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
