      <mxGeometry x="1465" y="120" width="1" height="930" as="geometry" />
    </mxCell>

    <!-- Step 1: User -> Router -->
    <mxCell id="200" value="POST /api/v1/orders  { payment_method }" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;fontSize=11;fontStyle=0;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="84" y="200" as="sourcePoint" /><mxPoint x="280" y="200" as="targetPoint" /></mxGeometry>
    </mxCell>

    <!-- Step 2: Router -> OrderService -->
    <mxCell id="201" value="place_order(user_id, method)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="280" y="260" as="sourcePoint" /><mxPoint x="510" y="260" as="targetPoint" /></mxGeometry>
