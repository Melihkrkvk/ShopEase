    <!-- Step 7: OrderService -> PaymentProvider -->
    <mxCell id="206" value="process(total)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333333;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="510" y="540" as="sourcePoint" /><mxPoint x="1225" y="540" as="targetPoint" /></mxGeometry>
