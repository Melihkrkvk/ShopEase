    <!-- Step 8: PaymentProvider -> OrderService (return) -->
    <mxCell id="207" value="success" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;dashed=1;fontSize=11;endArrow=open;endFill=0;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="1225" y="590" as="sourcePoint" /><mxPoint x="510" y="590" as="targetPoint" /></mxGeometry>
