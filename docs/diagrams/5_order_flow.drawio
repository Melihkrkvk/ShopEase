    <!-- Step 12: notify loop label -->
    <mxCell id="211" value="loop  [for each observer]" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="530" y="770" width="180" height="20" as="geometry" />
    </mxCell>

    <!-- Step 13: OrderService -> Observers -->
    <mxCell id="212" value="on_order_placed(order)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontColor=#b85450;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
